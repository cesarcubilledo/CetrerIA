<title>CetrerIA | Inteligencia Artificial para todos</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>

:root{
--naranja:#E67E22;
--terracota:#D35400;
--beige:#FFF8F0;
--arena:#F5E6D3;
--oscuro:#3E2F24;
--blanco:#ffffff;
}

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:'Poppins',sans-serif;
background:var(--beige);
color:var(--oscuro);
line-height:1.7;
}

.hero{
min-height:100vh;
display:flex;
align-items:center;
padding:60px;
background:linear-gradient(
135deg,
#fff8f0 0%,
#f5e6d3 100%
);
}

.hero-content{
max-width:1300px;
margin:auto;
display:grid;
grid-template-columns:1fr 1fr;
gap:60px;
align-items:center;
}

.hero-text h1{
font-size:4rem;
line-height:1.1;
margin-bottom:20px;
color:var(--terracota);
}

.hero-text p{
font-size:1.2rem;
margin-bottom:30px;
}

.badge{
display:inline-block;
background:#ffe3c4;
color:var(--terracota);
padding:10px 18px;
border-radius:30px;
font-weight:600;
margin-bottom:25px;
}

.botones{
display:flex;
gap:15px;
flex-wrap:wrap;
}

.btn{
padding:15px 28px;
border-radius:40px;
text-decoration:none;
font-weight:600;
transition:.3s;
}

.btn-primary{
background:var(--naranja);
color:white;
}

.btn-secondary{
background:white;
border:2px solid var(--terracota);
color:var(--terracota);
}

.btn:hover{
transform:translateY(-3px);
}

.hero-image img{
width:100%;
border-radius:25px;
box-shadow:0 15px 40px rgba(0,0,0,.15);
}

section{
padding:80px 25px;
}

.container{
max-width:1200px;
margin:auto;
}

h2{
text-align:center;
font-size:2.2rem;
margin-bottom:50px;
color:var(--terracota);
}

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
gap:25px;
}

.card{
background:white;
padding:30px;
border-radius:20px;
box-shadow:0 5px 15px rgba(0,0,0,.08);
}

.card h3{
margin-bottom:15px;
color:var(--terracota);
}

.card a{
display:inline-block;
margin-top:15px;
color:var(--naranja);
font-weight:700;
text-decoration:none;
}

.video-wrapper{
position:relative;
overflow:hidden;
aspect-ratio:16/9;
border-radius:20px;
box-shadow:0 15px 40px rgba(0,0,0,.15);
}

.video-wrapper iframe{
position:absolute;
top:0;
left:0;
width:100%;
height:100%;
border:none;
}

.audio-box{
background:white;
padding:30px;
border-radius:20px;
box-shadow:0 5px 15px rgba(0,0,0,.08);
}

audio{
width:100%;
}

.chat-section{
background:var(--arena);
}

.cta{
text-align:center;
}

.cta p{
font-size:1.1rem;
max-width:700px;
margin:0 auto 30px;
}

footer{
background:var(--oscuro);
color:white;
padding:50px 20px;
text-align:center;
}

footer p{
margin:8px 0;
}

@media(max-width:900px){

.hero{
padding:40px 20px;
}

.hero-content{
grid-template-columns:1fr;
}

.hero-text{
text-align:center;
}

.hero-text h1{
font-size:2.8rem;
}

.botones{
justify-content:center;
}

}

</style>
</head>

